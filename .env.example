# Eventra / eventkit — environment variables (no secrets)
# Copy to .env for local development: cp .env.example .env

# -----------------------------------------------------------------------------
# Logging (OBSERVABILITY)
# -----------------------------------------------------------------------------
# tracing filter directives (see https://docs.rs/tracing-subscriber/latest/tracing_subscriber/filter/struct.EnvFilter.html)
RUST_LOG=info,eventkit=debug,eventkit_obs=debug,phenotype_event_bus=debug

# Log output format: plain | json
EVENTKIT_LOG_FORMAT=plain

# -----------------------------------------------------------------------------
# Health probes
# -----------------------------------------------------------------------------
# Port for optional HTTP /health and /ready server (when http-health feature enabled)
EVENTKIT_HEALTH_PORT=8080

# CLI healthcheck HTTP timeout (milliseconds)
EVENTKIT_HEALTHCHECK_TIMEOUT_MS=3000

# -----------------------------------------------------------------------------
# Metrics (optional — wire via MetricsHook in your service binary)
# -----------------------------------------------------------------------------
# EVENTKIT_METRICS_ENABLED=true
# EVENTKIT_METRICS_PREFIX=eventkit

# -----------------------------------------------------------------------------
# Outbox relay (when running phenotype-event-bus relay workers)
# -----------------------------------------------------------------------------
# OUTBOX_POLL_INTERVAL_MS=500
# OUTBOX_BATCH_SIZE=100
# OUTBOX_SHUTDOWN_TIMEOUT_SECS=30

# -----------------------------------------------------------------------------
# Database (future Postgres adapter — placeholders only)
# -----------------------------------------------------------------------------
# DATABASE_URL=postgres://eventkit:eventkit@localhost:5432/eventkit
# DATABASE_POOL_SIZE=10

# -----------------------------------------------------------------------------
# Deploy / runtime
# -----------------------------------------------------------------------------
# RUST_BACKTRACE=1
# TOKIO_WORKER_THREADS=4
